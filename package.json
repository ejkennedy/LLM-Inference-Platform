{
  "name": "llm-inference-platform",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "workers/*",
    "shared/*"
  ],
  "scripts": {
    "build": "npm run build --workspace @llm-inference-platform/types && npm run build --workspace @llm-inference-platform/router && npm run build --workspace @llm-inference-platform/observability && npm run build --workspace @llm-inference-platform/gateway",
    "dev:gateway": "cd workers/gateway && npm run dev",
    "dev:gateway:remote": "cd workers/gateway && npm run dev:remote",
    "dev:router": "cd workers/router && npm run dev",
    "dev:observability": "cd workers/observability && npm run dev",
    "setup:local-auth": "node scripts/setup_local_auth.mjs",
    "token:dev": "node scripts/generate_dev_jwt.mjs",
    "lint": "echo 'Add lint scripts later'",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.2026.0",
    "@types/node": "^25.5.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.2",
    "wrangler": "^4.78.0"
  }
}
